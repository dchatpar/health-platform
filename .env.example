# Database
DATABASE_URL="postgresql://health:health_password@localhost:5432/health_platform?schema=public"
DATABASE_DIRECT_URL="postgresql://health:health_password@localhost:5432/health_platform"
DB_PASSWORD=health_password

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_URL=redis://default:redis_password@localhost:6379

# MongoDB
MONGO_PASSWORD=mongo_password
MONGODB_URI="mongodb://health:mongo_password@localhost:27017/health_platform?authSource=admin"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=1h
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# AWS S3
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_NAME=health-platform-uploads

# App
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002

# Frontend URLs (for CORS)
EXPO_PUBLIC_API_URL=http://localhost:3000
EXPO_PUBLIC_SOCKET_URL=http://localhost:3000
